# ================================
# SHARED ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your values
# ================================

# Supabase Configuration (ALL APPS)
NEXT_PUBLIC_SUPABASE_URL=https://hviqoaokxvlancmftwuo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_PROJECT_ID=hviqoaokxvlancmftwuo

# Service Role Key (ADMIN SCRIPTS ONLY - Keep secret!)
# Get this from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (BOOKING APP ONLY)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Super Admin (ADMIN APP ONLY)
NEXT_PUBLIC_ENABLE_SUPER_ADMIN=true

# AWS Configuration (EDGE FUNCTIONS)
AWS_ACCESS_KEY_ID=AKIAWYD3TYXVUCJFZA6H
AWS_SECRET_ACCESS_KEY=your-aws-secret-here
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@drive-247.com
ADMIN_EMAIL=admin@drive-247.com

# Resend (EDGE FUNCTIONS — primary email transport, replaces AWS SES)
# Get this from: https://resend.com/api-keys
# Set on Supabase: supabase secrets set RESEND_API_KEY=re_xxx --project-ref hviqoaokxvlancmftwuo


# OpenAI (EDGE FUNCTIONS — used by ai-suggest-next-action, ai-rank-matches,
# ai-extract-from-conversation, ai-draft-message, generate-review-summary)
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_KEY_FALLBACK=sk-your-openai-fallback-key-here

# Custom auth email hook secret (EDGE FUNCTIONS — custom-auth-email)
SEND_EMAIL_HOOK_SECRET=your-supabase-auth-hook-secret-here

# Vercel/Deployment
NEXT_PUBLIC_SITE_URL=https://drive-247.com

# Stripe Metered Billing (E-Sign Usage — separate price per mode)
