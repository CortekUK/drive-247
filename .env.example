# ─────────────────────────────────────────────────────────────────────────────
# Finance Sync — Xero + Zoho Books (Sprints 2 + 5)
# Set in Supabase project secrets (not committed). Required for OAuth + sync.
# ─────────────────────────────────────────────────────────────────────────────

# Xero — register your app at https://developer.xero.com → My Apps → New app
XERO_CLIENT_ID=215B9D08085C4B9196424DEAD18E36FF
XERO_CLIENT_SECRET=JvANplrqb2tUJhsuGLOcxJLyW2SVEo8zvo7msjXNwddd_1ub
XERO_REDIRECT_URI=https://hviqoaokxvlancmftwuo.supabase.co/functions/v1/xero-oauth-callback
XERO_WEBHOOK_KEY=                                 # Phase 2+ (webhook ingestion)

# Zoho Books — register at https://api-console.zoho.com → Add Client → Server-based
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=https://hviqoaokxvlancmftwuo.supabase.co/functions/v1/zoho-oauth-callback
ZOHO_WEBHOOK_KEY=                                 # Phase 2+ (webhook ingestion)

# Shared sync-worker tuning (defaults match spec §3 — only override per-tenant if needed)
ACCOUNTING_SYNC_BATCH_SIZE=100                    # rows picked per cron tick
ACCOUNTING_SYNC_RATE_LIMIT_XERO=50                # Xero allows 60/min — we cap below
ACCOUNTING_SYNC_RATE_LIMIT_ZOHO=80                # Zoho allows 100/min — we cap below
ACCOUNTING_SYNC_DEAD_LETTER_AFTER=5               # attempts before dead-letter (spec §14)